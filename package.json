{
    "name": "decorator-next",
    "private": "true",
    "version": "0.0.1",
    "description": "",
    "packageManager": "pnpm@10.32.0+sha512.9b2634bb3fed5601c33633f2d92593f506270a3963b8c51d2b2d6a828da615ce4e9deebef9614ccebbc13ac8d3c0f9c9ccceb583c69c8578436fa477dbb20d70",
    "engines": {
        "node": ">=24"
    },
    "scripts": {
        "storybook": "storybook dev -p 6006",
        "build-storybook": "storybook build",
        "test": "pnpm -r run test",
        "lint": "pnpm -r run lint",
        "lint:client": "pnpm --filter decorator-client run lint",
        "lint:server": "pnpm --filter decorator-server run lint",
        "lint:icons": "pnpm --filter decorator-icons run lint",
        "lint:shared": "pnpm --filter decorator-shared run lint",
        "lint:next": "pnpm --filter next-pages-router-example run lint",
        "dev": "concurrently \"pnpm --filter decorator-client run dev\" \"pnpm --filter decorator-server run dev\"",
        "build": "pnpm --filter decorator-icons run build && pnpm --filter decorator-client run build && pnpm --filter decorator-server run build && pnpm run copy-assets",
        "copy-assets": "mkdir -p packages/server/public && copyfiles -u 3 packages/client/dist/assets/**/* packages/server/public/",
        "prepare": "husky",
        "benchmarking": "./benchmarking/run",
        "playwright": "pnpm exec playwright test"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "workspaces": [
        "packages/*"
    ],
    "dependencies": {
        "@types/umami": "2.10.1",
        "clsx": "2.1.1",
        "zod": "4.3.6"
    },
    "dependencyComments": {
        "storybook": "Need to have matching storybook version across all storybook packages for it to work properly."
    },
    "devDependencies": {
        "@axe-core/playwright": "4.11.0",
        "@eslint/eslintrc": "3.3.5",
        "@eslint/js": "9.39.4",
        "@playwright/test": "1.58.0",
        "@storybook/addon-docs": "10.2.10",
        "@storybook/html": "10.2.10",
        "@storybook/html-vite": "10.2.10",
        "@types/node": "catalog:",
        "@typescript-eslint/eslint-plugin": "8.54.0",
        "@typescript-eslint/parser": "8.54.0",
        "concurrently": "9.2.1",
        "copyfiles": "2.4.1",
        "esbuild-minify-templates": "catalog:",
        "eslint": "catalog:",
        "http-server": "14.1.1",
        "husky": "9.1.7",
        "lint-staged": "16.2.7",
        "postcss-import-sync2": "1.2.0",
        "prettier": "3.8.1",
        "storybook": "10.2.10",
        "typescript": "catalog:",
        "typescript-plugin-css-modules": "5.2.0",
        "vite": "7.3.1"
    },
    "lint-staged": {
        "*.{ts,tsx,js}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{json,css,html,yaml,md}": [
            "prettier --write"
        ]
    },
    "prettier": {}
}
