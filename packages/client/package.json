{
    "name": "decorator-client",
    "version": "0.0.1",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "pnpm run build-main && pnpm run build-csr",
        "build:watch": "vite build --watch --mode main",
        "build-main": "vite build --mode main",
        "build-csr": "vite build --mode csr",
        "test": "TZ=UTC NODE_OPTIONS=--no-experimental-webstorage vitest run",
        "test:watch": "TZ=UTC NODE_OPTIONS=--no-experimental-webstorage vitest watch",
        "lint": "eslint . && tsc --noEmit"
    },
    "dependenciesComments": {
        "@grafana/faro-web-sdk": "Type-only import. Faro is initialized by xp-frontend, keep version in sync."
    },
    "dependencies": {
        "@grafana/faro-web-sdk": "2.6.3",
        "@navikt/ds-css": "8.10.6",
        "decorator-icons": "workspace:*",
        "decorator-shared": "workspace:*",
        "js-cookie": "3.0.5",
        "lodash.debounce": "4.0.8"
    },
    "devDependencies": {
        "@open-wc/testing": "4.0.0",
        "@types/js-cookie": "3.0.6",
        "@types/lodash.debounce": "4.0.9",
        "jsdom": "27.4.0",
        "postcss": "catalog:",
        "rollup-plugin-minify-html-literals-v3": "1.3.4",
        "vitest": "catalog:"
    }
}
