{
    "name": "decorator-server",
    "version": "0.0.1",
    "module": "src/server.ts",
    "type": "module",
    "scripts": {
        "dev": "tsx --import ./css-module-register.ts --env-file=.env --watch src/server.ts",
        "postinstall": "node -e \"const fs=require('fs'); if(!fs.existsSync('.env')) fs.copyFileSync('.env.sample', '.env')\"",
        "serve": "cross-env NODE_ENV=production node dist/server.js",
        "serve-local": "cross-env NODE_ENV=production APP_URL=http://localhost:8089 tsx --import ./css-module-register.ts --env-file=.env --watch src/server.ts",
        "clean": "node -e \"require('fs').rmSync('./public/assets', {recursive: true, force: true})\"",
        "build": "pnpm run clean && cross-env NODE_ENV=production tsx build.ts",
        "test": "vitest run",
        "lint": "eslint . && tsc --noEmit"
    },
    "dependencies": {
        "@hono/node-server": "1.19.14",
        "@hono/prometheus": "1.0.3",
        "csp-header": "6.3.1",
        "decorator-client": "workspace:*",
        "decorator-icons": "workspace:*",
        "decorator-shared": "workspace:*",
        "hono": "4.12.25",
        "ts-pattern": "5.9.0",
        "unleash-client": "6.11.0"
    },
    "devDependencies": {
        "@types/node": "catalog:",
        "cross-env": "10.1.0",
        "esbuild": "0.25.12",
        "msw": "2.14.6",
        "postcss": "catalog:",
        "postcss-import": "16.1.1",
        "postcss-modules": "6.0.1",
        "tsx": "catalog:",
        "vitest": "catalog:"
    }
}
