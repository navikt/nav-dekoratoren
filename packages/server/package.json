{
    "name": "decorator-server",
    "version": "0.0.1",
    "module": "src/server.ts",
    "type": "module",
    "scripts": {
        "dev": "tsx --import ./css-module-register.ts --env-file=.env --watch src/server.ts",
        "postinstall": "cp .env.sample .env",
        "serve": "NODE_ENV=production node dist/server.js",
        "serve-local": "NODE_ENV=production APP_URL=http://localhost:8089 tsx --import ./css-module-register.ts --env-file=.env --watch src/server.ts",
        "clean": "rm -rf ./public/assets",
        "build": "pnpm run clean && NODE_ENV=production tsx build.ts",
        "test": "vitest run",
        "lint": "eslint . && tsc --noEmit"
    },
    "dependencies": {
        "@hono/node-server": "1.19.13",
        "@hono/prometheus": "1.0.2",
        "csp-header": "6.3.0",
        "decorator-client": "workspace:*",
        "decorator-icons": "workspace:*",
        "decorator-shared": "workspace:*",
        "hono": "4.12.14",
        "ts-pattern": "5.9.0",
        "unleash-client": "6.9.4"
    },
    "devDependencies": {
        "@types/node": "catalog:",
        "esbuild": "0.25.8",
        "esbuild-minify-templates": "catalog:",
        "msw": "2.12.10",
        "postcss": "catalog:",
        "postcss-import": "16.1.1",
        "postcss-modules": "6.0.1",
        "tsx": "catalog:",
        "vitest": "catalog:"
    }
}
